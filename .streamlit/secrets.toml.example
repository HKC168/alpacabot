# 複製此檔為 .streamlit/secrets.toml 並填入真實金鑰
# secrets.toml 不可提交到 GitHub（已加入 .gitignore）
#
# Streamlit Cloud 部署時，在 App Settings → Secrets 貼入以下內容
# 文件：https://docs.streamlit.io/develop/concepts/connections/secrets-management

# 帳戶 ID 列表（可加入多個帳戶）
[accounts]
ids = ["PA3CVCWGFPAM"]

# 各帳戶設定（以帳戶 ID 為 section 名稱）
[PA3CVCWGFPAM]
name             = "Han Paper Account"
api_key          = "PKGIY77BCOGGXDCNBZCCFXWK23"
secret_key       = "AaKf28rmopcf4EuCaizsQcZk4zzYp4RofE1xBGooBjE6"
endpoint         = "https://paper-api.alpaca.markets"
active_strategy  = "top10_nasdaq_equal"
email            = "gavin1.han@gmail.com"

